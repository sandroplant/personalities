{
  "compilerOptions": {
    "target": "ES6",
    "module": "ESNext",
    "lib": ["es2020", "dom"],
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": false,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "outDir": "./dist",
    "rootDir": "./",
    "removeComments": true,
    "typeRoots": ["./node_modules/@types", "./server/src/types"]
  },
  "include": [
    "server/**/*.ts",
    "webpack.config.ts",
    "reportWebVitals.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "build"
  ]
}