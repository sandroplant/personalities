{
  "extends": "/Users/aniavsa/Desktop/personalities/tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "module": "NodeNext",                // Use `NodeNext` to support `import.meta`
    "moduleResolution": "NodeNext",      // Use `NodeNext` module resolution
    "target": "ES2022",                  // Target a compatible ECMAScript version
    "rootDir": "./src",                  // Set root directory to `src` for organization
    "esModuleInterop": true,             // Allow interoperability between CommonJS and ES Modules
    "strict": true,                      // Enable all strict type-checking options
    "resolveJsonModule": true            // Allow importing JSON files
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
