{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./server/dist",                // Output compiled files to server/dist
    "rootDir": "./server/src",                // Set root directory for source files in server/src
    "module": "NodeNext",                     // Use NodeNext to support ESM in Node.js
    "moduleResolution": "NodeNext",           // Use NodeNext for module resolution
    "target": "ES2022",                       // Target ECMAScript 2022 for latest features
    "esModuleInterop": true,                  // Enable interoperability between CommonJS and ESM
    "strict": true,                           // Enable strict type-checking
    "resolveJsonModule": true,                // Allow importing of JSON files
    "skipLibCheck": true,                     // Skip type checking of declaration files
    "forceConsistentCasingInFileNames": true, // Enforce consistent casing in import statements
    "noImplicitAny": true,                    // Disallow explicit use of `any`
    "noUnusedLocals": true,                   // Warn on unused local variables
    "noUnusedParameters": true,               // Warn on unused parameters
    "noFallthroughCasesInSwitch": true,       // Prevent fallthrough errors in switch statements
    "noEmitOnError": true                     // Prevent emitting files if there are type errors
  },
  "include": [
    "server/src/**/*.ts"                      // Include all TypeScript files in the server/src folder
  ],
  "exclude": [
    "node_modules",                           // Exclude node_modules folder
    "server/dist"                             // Exclude server/dist folder (output folder)
  ]
}
