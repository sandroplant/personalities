{
  "compilerOptions": {
    "target": "ES6",
    "module": "ESNext",
    "lib": ["es2020", "dom"],
    "jsx": "react-jsx",
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "removeComments": true,
    "typeRoots": [
      "./node_modules/@types",
      "./server/src/types"                      // Ensure custom types are included
    ]
  }
}
