# Logs
logs/
*.log

# OS generated files
.DS_Store

# Coverage directory used by testing tools
coverage/

# Temporary files
tmp/
temp/
*.tmp

# Git related files
# .git and .gitignore should NOT be ignored

# VS Code settings
.vscode/

# Dependencies
node_modules/

# Allow specific documents if they are in the server directory
!terms-of-service.md
!privacy-policy.md
!data-deletion.md

# Server-specific ignores
server/logs/
server/temp/
server/*.tmp
server/node_modules/

# Ignore dist folder
dist/

# Ignore environment files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

