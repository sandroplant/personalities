    "@types/spotify-web-api-node": "^5.0.0",
    "@types/winston": "^2.4.4",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^4.2.1",
