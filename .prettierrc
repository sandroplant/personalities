{
  "semi": true,
  "singleQuote": true,
  "tabWidth": 2,
  "trailingComma": "es5",
  "printWidth": 80,
  "overrides": [
    {
      "files": "server/**/*.js",
      "options": {
        "tabWidth": 4
      }
    },
    {
      "files": "client/**/*.jsx",
      "options": {
        "tabWidth": 2
      }
    }
  ]
}