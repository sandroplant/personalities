# =============================
# Node Modules and Dependencies
# =============================

# Ignore all node_modules directories
/node_modules/
client/node_modules/
server/node_modules/

# =====================
# Environment Variables
# =====================

# Ignore environment variable files
*.env
.env

# =====================
# Build and Distribution
# =====================

# Ignore build and distribution folders
/dist/
build/
coverage/

# =====================
# Logs and Debugging
# =====================

# Ignore log files and directories
logs/
*.log
npm-debug.log*

# =====================
# Operating System Files
# =====================

# macOS
.DS_Store

# =====================
# Temporary Files
# =====================

# Ignore temporary files and directories
tmp/
temp/
*.tmp

# =====================
# Editor and IDE Settings
# =====================

# VS Code settings
.vscode/

# =====================
# Git Specific Files
# =====================

# Do NOT ignore .git or .gitignore
# These lines have been removed as Git manages them internally

# =====================
# Documentation Exceptions
# =====================

# Allow specific documents in the client directory
!client/src/documents/terms-of-service.md
!client/src/documents/privacy-policy.md
!client/src/documents/data-deletion.md

# Allow specific documents in the server directory
!server/terms-of-service.md
!server/privacy-policy.md
!server/data-deletion.md
