# =============================
# Node Modules and Dependencies
# =============================

# Ignore all node_modules directories
node_modules/
server/node_modules/
client/node_modules/

# =====================
# Environment Variables
# =====================

# Ignore environment variable files (for security)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Server-specific environment variables
server/.env

# Client-specific environment variables
client/.env

# =====================
# Build and Distribution
# =====================

# Ignore build and distribution folders
dist/
server/dist/
client/build/
build/
coverage/

# =====================
# Cache and Temporary Files
# =====================

# Ignore cache and temporary files
.cache/
.tmp/
tmp/
temp/
server/temp/
server/*.tmp
client/.tmp/

# =====================
# Logs and Debugging
# =====================

# Ignore log files and directories
logs/
server/logs/
client/logs/

# General log files
*.log

# npm and Yarn debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# =====================
# Operating System Files
# =====================

# macOS Finder metadata
.DS_Store

# Windows Thumbs.db
Thumbs.db

# =====================
# Editor and IDE Settings
# =====================

# Visual Studio Code
.vscode/

# IntelliJ IDEA
.idea/

# Sublime Text project files
*.sublime-workspace
*.sublime-project

# =====================
# Documentation Exceptions
# =====================

# Allow specific documentation files in server and client directories
!server/terms-of-service.md
!server/privacy-policy.md
!server/data-deletion.md
!client/src/documents/terms-of-service.md
!client/src/documents/privacy-policy.md
!client/src/documents/data-deletion.md

# =====================
# ESLint and Prettier
# =====================

# Ignore ESLint cache
.eslintcache

# =====================
# Other
# =====================

# Ignore lock files for specific tools
.lock-wscript

# =====================
# Webpack Configuration
# =====================

# If you decide to move webpack.config.js to the client directory, ignore the root one
# Uncomment the following line if you keep webpack.config.js in the root and don't want to track it
# webpack.config.js

# =====================
# Miscellaneous
# =====================

# Ignore swap files
*.swp
*.swo
