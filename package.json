{
  "name": "my-express-app",
  "version": "1.0.0",
  "description": "A secure Express server with Webpack and Babel integration",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node server/dist/app.js",
    "build": "npm run build:server && npm run build:client",
    "build:server": "tsc -p server/",
    "build:client": "npm run build --prefix client",
    "dev:server": "nodemon --watch server/src --exec ts-node --esm server/src/app.ts",
    "dev:client": "npm run start --prefix client",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "clean": "rm -rf dist build client/build logs && npm cache clean --force"
  },
  "dependencies": {
    "axios": "^1.7.7",
    "bcrypt": "^5.1.1",
    "cloudinary": "^2.5.1",
    "compression": "^1.7.4",
    "cookie": "^1.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "csrf": "^3.1.0",
    "dotenv": "^16.4.5",
    "dotenv-flow": "^4.1.0",
    "express": "^4.21.1",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.4.1",
    "express-session": "^1.18.1",
    "express-validator": "^7.2.0",
    "fs-extra": "^11.2.0",
    "helmet": "^8.0.0",
    "hpp": "^0.2.3",
    "jsonwebtoken": "^9.0.2",
    "lodash": "^4.17.21",
    "mongoose": "^8.7.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "node-fetch": "^3.3.2",
    "openai": "^4.67.3",
    "rate-limiter-flexible": "^5.0.3",
    "session-file-store": "^1.5.0",
    "socket.io": "^4.8.0",
    "socket.io-client": "^4.8.0",
    "spotify-web-api-node": "^5.0.2",
    "web-vitals": "^4.2.3",
    "winston": "^3.15.0",
    "xss": "^1.0.15",
    "xss-clean": "^0.1.4"
  },
  "devDependencies": {
    "@babel/core": "^7.25.7",
    "@babel/eslint-parser": "^7.25.7",
    "@babel/preset-react": "^7.25.7",
    "@testing-library/jest-dom": "^6.6.2",
    "@testing-library/react": "^16.0.1",
    "@types/bcrypt": "^5.0.2",
    "@types/compression": "^1.7.5",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/dotenv-webpack": "^7.0.7",
    "@types/express": "^4.17.17",
    "@types/express-rate-limit": "^5.1.3",
    "@types/express-session": "^1.17.5",
    "@types/hpp": "^0.2.6",
    "@types/html-webpack-plugin": "^3.2.9",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/morgan": "^1.9.4",
    "@types/multer": "^1.4.12",
    "@types/node": "^20.6.2",
    "@types/node-fetch": "^2.6.11",
    "@types/react-bootstrap": "^0.32.37",
    "@types/react-router-dom": "^5.3.3",
    "@types/session-file-store": "^1.2.5",
    "@types/spotify-web-api-node": "^5.0.11",
    "@types/webpack": "^5.28.5",
    "@types/webpack-dev-server": "^4.7.1",
    "@types/winston": "^2.4.4",
    "@typescript-eslint/eslint-plugin": "^8.11.0",
    "@typescript-eslint/parser": "^8.11.0",
    "babel-loader": "^9.1.2",
    "concurrently": "^9.0.1",
    "css-minimizer-webpack-plugin": "^7.0.0",
    "dotenv-webpack": "^8.1.0",
    "eslint": "^8.57.1",
    "eslint-config-airbnb": "^19.0.4",
    "eslint-config-prettier": "^9.1.0",
    "eslint-import-resolver-node": "^0.3.9",
    "eslint-import-resolver-typescript": "^3.5.5",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-jest": "^28.8.3",
    "eslint-plugin-jsx-a11y": "^6.7.1",
    "eslint-plugin-prettier": "^4.2.1",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^4.6.2",
    "html-webpack-plugin": "^5.5.3",
    "jest": "^29.7.0",
    "nodemon": "^3.0.1",
    "prettier": "^2.8.8",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "5.1.6",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.1.0"
  },
  "resolutions": {
    "globals": "15.0.1"
  },
  "jest": {
    "setupFilesAfterEnv": [
      "<rootDir>/client/src/setupTests.ts"
    ],
    "testEnvironment": "jsdom"
  }
}
